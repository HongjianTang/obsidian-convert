{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/HongjianTang/obsidian-convert/schemas/conversion-report.json",
  "title": "Obsidian Convert Report",
  "description": "Schema for conversion report generated by obsidian-convert",
  "type": "object",
  "required": ["version", "generatedAt", "summary", "files", "errors", "warnings"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Report format version",
      "examples": ["1.0.0"]
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the report was generated"
    },
    "summary": {
      "type": "object",
      "description": "Summary statistics for the conversion",
      "required": ["totalFiles", "successCount", "failedCount", "warningCount", "totalWikiLinks", "totalCallouts", "totalAttachments", "durationMs", "startTime", "endTime"],
      "properties": {
        "totalFiles": {
          "type": "integer",
          "minimum": 0,
          "description": "Total files processed"
        },
        "successCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Successfully converted files"
        },
        "failedCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Failed conversions"
        },
        "warningCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Total warnings generated"
        },
        "totalWikiLinks": {
          "type": "integer",
          "minimum": 0,
          "description": "Total WikiLinks converted"
        },
        "totalCallouts": {
          "type": "integer",
          "minimum": 0,
          "description": "Total callouts converted"
        },
        "totalAttachments": {
          "type": "integer",
          "minimum": 0,
          "description": "Total attachments processed"
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0,
          "description": "Conversion duration in milliseconds"
        },
        "peakMemoryBytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Peak memory usage in bytes"
        },
        "startTime": {
          "type": "string",
          "format": "date-time",
          "description": "Conversion start time"
        },
        "endTime": {
          "type": "string",
          "format": "date-time",
          "description": "Conversion end time"
        }
      }
    },
    "files": {
      "type": "array",
      "description": "Successfully converted files",
      "items": {
        "$ref": "#/definitions/ReportFile"
      }
    },
    "errors": {
      "type": "array",
      "description": "Failed conversions with error details",
      "items": {
        "$ref": "#/definitions/ReportError"
      }
    },
    "warnings": {
      "type": "array",
      "description": "Warnings generated during conversion",
      "items": {
        "$ref": "#/definitions/ReportWarning"
      }
    }
  },
  "definitions": {
    "ReportFile": {
      "type": "object",
      "required": ["sourcePath", "outputPath", "wikiLinkCount", "calloutCount", "attachmentCount", "sourceSizeBytes", "outputSizeBytes"],
      "properties": {
        "sourcePath": {
          "type": "string",
          "description": "Source file path"
        },
        "outputPath": {
          "type": "string",
          "description": "Output file path"
        },
        "wikiLinkCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of WikiLinks converted"
        },
        "calloutCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of callouts converted"
        },
        "attachmentCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of attachments processed"
        },
        "sourceSizeBytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Source file size in bytes"
        },
        "outputSizeBytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Output file size in bytes"
        }
      }
    },
    "ReportError": {
      "type": "object",
      "required": ["sourcePath", "errorMessage", "timestamp"],
      "properties": {
        "sourcePath": {
          "type": "string",
          "description": "Source file path"
        },
        "errorMessage": {
          "type": "string",
          "description": "Error message"
        },
        "stackTrace": {
          "type": "string",
          "description": "Error stack trace (if available)"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the error occurred"
        }
      }
    },
    "ReportWarning": {
      "type": "object",
      "required": ["type", "file", "message", "timestamp"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["broken-link", "format-issue", "missing-frontmatter", "orphan-file", "attachment-missing"],
          "description": "Type of warning"
        },
        "file": {
          "type": "string",
          "description": "File where the warning originated"
        },
        "target": {
          "type": "string",
          "description": "Target or subject of the warning"
        },
        "message": {
          "type": "string",
          "description": "Human-readable warning message"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the warning occurred"
        }
      }
    }
  }
}
